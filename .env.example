# Environment: demo | testnet | live (start on demo)
TRADING_ENV=demo
AUTO_START=false                # true in cloud to launch the engine on boot

# Bybit (demo keys from the mainnet demo-trading page)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_API_PRIVATE_KEY_PATH=     # optional RSA key path; blank = HMAC

# LLM via OpenRouter (one key — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=minimax/minimax-m3

# News/sentiment — Exa is the primary source (https://exa.ai)
EXA_API_KEY=
CRYPTOPANIC_API_KEY=            # optional paid fallback

# Storage — cloud (Timescale Cloud / Upstash) or local docker-compose
DATABASE_URL=    # postgresql://USER:PW@HOST:PORT/tsdb?sslmode=require  (local: ...@localhost:5432/crypto_bot)
REDIS_URL=       # rediss://default:PW@HOST:6379  (local: redis://localhost:6379/0)

# Observability (optional)
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=dev

# Scanning / loop
UNIVERSE_MAX_SYMBOLS=150         # pairs scanned per cycle (0 = entire market)
MAX_CANDIDATES=25               # top-ranked candidates to act on
MAX_NEW_ORDERS_PER_CYCLE=3
CYCLE_SECONDS=60                # loop cadence in seconds (lower = faster, more API load)

# Risk
RISK_PER_TRADE_PCT=1.0          # % of equity risked per trade
MAX_POSITION_PCT=20.0           # max % of equity in a single position
DAILY_LOSS_HALT_PCT=5.0         # halt trading if daily P&L <= -this%
MAX_LEVERAGE=3.0                # hard cap on perps leverage
